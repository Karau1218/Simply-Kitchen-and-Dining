<!DOCTYPE html>
<html lang="en">

<head>
    <title>Shop Products — Sustainably</title>
    <%- include("partials/head") %>
        <script src="/js/kitchen.js" defer></script>
</head>

<body>

    <%- include("partials/header") %>

        <main class="container section">
            <div class="section-head">
                <h1 class="section-title">Shop All Products</h1>
                <p class="section-sub">Eco-friendly kitchen essentials for a cleaner home.</p>
            </div>

            <section class="filter-bar">
                <div class="filter-group">
                    <label for="product-search">Search</label>
                    <input type="text" id="product-search" placeholder="Search name or description..."
                        value="<%= searchTerm || '' %>">
                </div>

                <div class="filter-group">
                    <label for="category-filter">Category</label>
                    <select id="category-filter">
                        <option value="All" <%=selectedCategory==="All" ? "selected" : "" %>>All</option>
                        <option value="Kitchen Tools" <%=selectedCategory==="Kitchen Tools" ? "selected" : "" %>>Kitchen
                            Tools</option>
                        <option value="Food Storage" <%=selectedCategory==="Food Storage" ? "selected" : "" %>>Food
                            Storage</option>
                        <option value="Drinkware" <%=selectedCategory==="Drinkware" ? "selected" : "" %>>Drinkware
                        </option>
                        <option value="Kitchen Linens" <%=selectedCategory==="Kitchen Linens" ? "selected" : "" %>
                            >Kitchen Linens</option>
                        <option value="Cleaning Supplies" <%=selectedCategory==="Cleaning Supplies" ? "selected" : "" %>
                            >Cleaning Supplies</option>
                        <option value="Dining" <%=selectedCategory==="Dining" ? "selected" : "" %>>Dining</option>
                    </select>
                </div>

                <div class="filter-group">
                    <label for="sort-filter">Sort</label>
                    <select id="sort-filter">
                        <option value="" <%=selectedSort==="" ? "selected" : "" %>>Featured</option>
                        <option value="price" <%=selectedSort==="price" ? "selected" : "" %>>Price: Low to High</option>
                        <option value="price_desc" <%=selectedSort==="price_desc" ? "selected" : "" %>>Price: High to
                            Low</option>
                    </select>
                </div>

                <button type="button" id="clear-filters" class="button ghost small">Clear</button>

                <div class="product-status">
                    Showing <span id="product-count">
                        <%= products.length %>
                    </span> products
                </div>
            </section>

            <hr class="divider" style="margin: 2rem 0; opacity: 0.2;">

            <div class="products" id="products-grid">
                <% products.forEach(product=> { %>
                    <article class="product-card">
                        <div class="product-img">
                            <img src="<%= product.imageUrl %>" alt="<%= product.productName %>">
                        </div>

                        <div class="product-info">
                            <h3 class="product-name">
                                <%= product.productName %>
                            </h3>
                            <p class="product-category">
                                <%= product.category %>
                            </p>
                            <p class="product-desc">
                                <%= product.productDescription %>
                            </p>
                            <p class="price">$<%= product.price %>
                            </p>

                            <div class="card-actions">
                                <button class="button primary small">Add to Cart</button>
                                <a href="/products/<%= product.productId %>" class="details-link">View Details</a>
                            </div>
                        </div>
                    </article>
                    <% }) %>
            </div>
        </main>

</body>

</html>