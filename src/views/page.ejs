<!DOCTYPE html>
<html lang="en">

<head>
    <title>Simply Kitchenware & Dining</title>
    <%- include("partials/head") %>
</head>

<body>

    <!-- Top Nav -->
    <%- include("partials/header") %>

        <!-- Hero -->
        <main>
            <section class="hero container">
                <div class="hero-left">
                    <p class="eyebrow">Sustainable Kitchenware & Dining</p>
                    <h1 class="hero-title">Simple essentials for a cleaner home.</h1>
                    <p class="hero-sub">
                        Reuseable, low-waste, and thoughtfully sourced products for everyday living — made to look good
                        and
                        last.
                    </p>

                    <div class="hero-cta">
                        <a class="button primary" href="/products">Shop Now</a>
                        <a class="button ghost" href="#mission">Our Mission</a>
                    </div>

                    <div class="hero-tags" aria-label="Highlights">
                        <span class="tag">Plastic-light</span>
                        <span class="tag">Compostable</span>
                        <span class="tag">Low-tox</span>
                        <span class="tag">Made to last</span>
                    </div>
                </div>

                <div class="hero-right">
                    <div class="hero-photo">
                        <img src="/images/kitchenware.webp" alt="Minimal sustainable home goods on a bright counter"
                            onerror="this.src='/images/kitchenware.webp'" />
                    </div>
                </div>
            </section>

            <!-- Collections Grid -->
            <section id="collections" class="section container">
                <div class="section-head">
                    <h2 class="section-title">Shop by collection</h2>
                    <p class="section-sub">Kitchen & Dining categories</p>
                </div>

                <div class="collections">
                    <a class="collection-card" href="/products?category=Food%20Storage">
                        <div class="circle">
                            <img src="/images/collection-storage.webp" alt="Food storage" onerror="this.remove()">
                        </div>
                        <h3>Food Storage</h3>
                        <p>Glass containers, silicone bags, beeswax wraps.</p>
                    </a>

                    <a class="collection-card" href="/products?category=Kitchen%20Tools">
                        <div class="circle">
                            <img src="/images/collection-tools.webp" alt="Cooking tools" onerror="this.remove()">
                        </div>
                        <h3>Cooking Tools</h3>
                        <p>Cutting boards, wooden spoons, dish brushes, sponges.</p>
                    </a>

                    <a class="collection-card" href="/products?category=Dining">
                        <div class="circle">
                            <img src="/images/collection-dining.webp" alt="Dining and serveware"
                                onerror="this.remove()">
                        </div>
                        <h3>Dining & Serveware</h3>
                        <p>Plates, salad bowls, pitchers, placemats.</p>
                    </a>

                    <a class="collection-card" href="/products?category=Drinkware">
                        <div class="circle">
                            <img src="/images/collection-drinkware.webp" alt="Drinkware and on-the-go"
                                onerror="this.remove()">
                        </div>
                        <h3>Drinkware & On-the-Go</h3>
                        <p>Water bottles, lunch boxes, straws, coffee filters.</p>
                    </a>
                </div>
            </section>


            <!-- Mission -->
            <section id="mission" class="section container">
                <div class="mission">
                    <div class="mission-text">
                        <h2 class="section-title">Better materials. Less waste.</h2>
                        <p class="section-sub">
                            We prioritize refill systems, durable materials, and minimal packaging so your home stays
                            clean
                            without extra clutter.
                        </p>

                        <ul class="checklist">
                            <li><span class="check">✓</span> Refillable + reusable options</li>
                            <li><span class="check">✓</span> Curated “buy less, buy better” catalog</li>
                            <li><span class="check">✓</span> Clean design that fits your space</li>
                        </ul>

                        <a class="button primary" href="/products">Browse Products</a>
                        <!-- <a href="/products?collection=refillable">Shop Refillable Products</a> -->

                    </div>

                    <div class="mission-photo">
                        <img src="/images/mission.webp" alt="Bright neutral sustainable products styled neatly"
                            onerror="this.src='/images/home.webp'" />
                    </div>
                </div>
            </section>

            <!-- Best Sellers -->
            <section id="bestsellers" class="section container">
                <div class="section-head">
                    <h2 class="section-title">Best sellers</h2>
                </div>

                <div class="products">
                    <% bestSellers.forEach(product=> { %>
                        <a href="/products/<%= product.productId %>" class="product-card best-seller-link">
                            <div class="product-img">
                                <img src="<%= product.imageUrl %>" alt="<%= product.productName %>">
                            </div>

                            <div class="product-info">
                                <h3>
                                    <%= product.productName %>
                                </h3>
                                <p class="price">$<%= product.price %>
                                </p>
                            </div>
                        </a>
                        <% }) %>
                </div>
            </section>

            <!-- Footer -->
            <footer class="footer">
                <div class="container footer-inner">
                    <div>
                        <div class="footer-brand">Simply Kitchenware & Dining </div>
                        <p class="footer-muted">Minimal, bright, low-waste kitchen & dining essentials.</p>
                    </div>

                    <div class="footer-links">
                        <a href="/products">Shop</a>
                        <a href="/login">Login</a>
                        <a href="/register">Register</a>
                    </div>
                </div>
            </footer>

        </main>
</body>

</html>